{
  "tasks": {
    "check": "deno fmt --check && deno lint && deno test",
    "test": "deno test",
    "test:contract": "deno test tests/contract",
    "dev": "deno run --allow-read --allow-write --allow-env --allow-net src/main.js",
    "dev:local": "deno run --env-file=../.env --allow-read --allow-write --allow-env --allow-net src/main.js"
  },
  "fmt": {
    "lineWidth": 100,
    "singleQuote": true,
    "semiColons": true
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  }
}
